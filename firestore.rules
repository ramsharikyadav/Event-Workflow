rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Get user data helper with existence check
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        (userExists() && getUserData().role == 'admin') || 
        request.auth.token.email == 'ramsharik.yadav@gmail.com'
      );
    }
    
    function isOrderer() { return isSignedIn() && userExists() && getUserData().role == 'orderer'; }
    function isVendor() { return isSignedIn() && userExists() && getUserData().role == 'vendor'; }
    function isStoreManager() { return isSignedIn() && userExists() && getUserData().role == 'storeManager'; }
    function isAccounts() { return isSignedIn() && userExists() && getUserData().role == 'accounts'; }
    function isEndUser() { return isSignedIn() && userExists() && getUserData().role == 'endUser'; }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Materials
    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isStoreManager(); 
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isOrderer();
      allow update: if isAdmin() || (
                      (isVendor() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      (isStoreManager() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'deliveredTo', 'handoverRemarks'])) ||
                      (isAccounts() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'updatedAt']))
                    );
      allow delete: if isAdmin();
    }

    // Receipts
    match /receipts/{receiptId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isStoreManager();
      allow delete: if isAdmin();
    }
  }
}
